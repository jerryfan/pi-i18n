{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/pi-i18n.bundle.schema.json",
  "title": "pi-i18n Bundle v1",
  "type": "object",
  "required": ["version", "namespace", "locale", "messages"],
  "properties": {
    "version": { "type": "integer", "enum": [1] },
    "namespace": { "type": "string", "minLength": 1 },
    "locale": { "type": "string", "minLength": 2 },
    "integration": {
      "type": "object",
      "properties": {
        "capability": { "type": "string", "enum": ["pi.i18n.v1"] },
        "provider": { "type": "string" },
        "coreCompat": {
          "type": "object",
          "properties": {
            "minContractVersion": { "type": "integer", "minimum": 1 },
            "detectionEvent": { "type": "string" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "messages": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["value"],
            "properties": {
              "description": { "type": "string" },
              "value": {
                "oneOf": [
                  { "type": "string" },
                  {
                    "type": "object",
                    "additionalProperties": { "type": "string" },
                    "minProperties": 1
                  }
                ]
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
